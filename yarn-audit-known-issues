{"type":"auditAdvisory","data":{"resolution":{"id":1113979,"path":"dompurify","dev":false,"bundled":false,"optional":false},"advisory":{"findings":[{"version":"3.3.1","paths":["dompurify"]}],"found_by":null,"deleted":null,"references":"- https://nvd.nist.gov/vuln/detail/CVE-2026-0540\n- https://github.com/cure53/DOMPurify/commit/fca0a938b4261ddc9c0293a289935a9029c049f5\n- https://github.com/cure53/DOMPurify\n- https://www.vulncheck.com/advisories/dompurify-xss-via-missing-rawtext-elements-in-safeforxml\n- https://www.vulncheck.com/advisories/dompurify-xss-via-missing-rawtext-elements-in-safe-for-xml\n- https://github.com/advisories/GHSA-v2wj-7wpq-c8vv","created":"2026-03-03T18:31:33.000Z","id":1113979,"npm_advisory_id":null,"overview":"DOMPurify 3.1.3 through 3.3.1 and 2.5.3 through 2.5.8, fixed in commit 729097f, contain a cross-site scripting vulnerability that allows attackers to bypass attribute sanitization by exploiting five missing rawtext elements (noscript, xmp, noembed, noframes, iframe) in the SAFE_FOR_XML regex. Attackers can include payloads like </noscript><img src=x onerror=alert(1)> in attribute values to execute JavaScript when sanitized output is placed inside these unprotected rawtext contexts.","reported_by":null,"title":"DOMPurify contains a Cross-site Scripting vulnerability","metadata":null,"cves":["CVE-2026-0540"],"access":"public","severity":"moderate","module_name":"dompurify","vulnerable_versions":">=3.1.3 <=3.3.1","github_advisory_id":"GHSA-v2wj-7wpq-c8vv","recommendation":"None","patched_versions":"<0.0.0","updated":"2026-03-04T20:51:56.000Z","cvss":{"score":6.1,"vectorString":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:C/C:L/I:L/A:N"},"cwe":["CWE-79"],"url":"https://github.com/advisories/GHSA-v2wj-7wpq-c8vv"}}}
