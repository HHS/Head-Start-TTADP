{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "license": "ISC",
  "dependencies": {
    "@babel/runtime": "^7.26.10",
    "@fortawesome/fontawesome-svg-core": "^7.0.0",
    "@fortawesome/free-solid-svg-icons": "^7.0.0",
    "@fortawesome/pro-solid-svg-icons": "^7.0.0",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@hookform/error-message": "^0.0.5",
    "@mesh-kit/core": "^1.0.0",
    "@react-hook/resize-observer": "^1.2.6",
    "@silevis/reactgrid": "3.1",
    "@trussworks/react-uswds": "5.1.0",
    "@uswds/uswds": "3.1.0",
    "@ttahub/common": "2.2.21",
    "@use-it/interval": "^1.0.0",
    "async": "^3.2.3",
    "classnames": "^2.5.1",
    "csv-parse": "^4.14.1",
    "detect-file-encoding-and-language": "^2.4.0",
    "dompurify": "^3.3.2",
    "draft-js": "^0.11.7",
    "draftjs-to-html": "^0.9.1",
    "ejs": "^3.1.7",
    "focus-trap-react": "^10.3.0",
    "follow-redirects": "^1.15.6",
    "html-react-parser": "^5.1.1",
    "html-to-draftjs": "^1.5.0",
    "html2canvas": "^1.4.1",
    "immutable": "^4.3.8",
    "http-proxy-middleware": "^3.0.5",
    "lodash": "^4.18.1",
    "micromatch": "^4.0.8",
    "minimist": "^1.2.6",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.35",
    "nth-check": "^2.0.1",
    "plotly.js": "^2.34.0",
    "plotly.js-basic-dist": "^2.34.0",
    "prop-types": "^15.7.2",
    "query-string": "^7.0.0",
    "react": "^17.0.1",
    "react-admin": "^3.19.12",
    "react-app-polyfill": "^3.0.0",
    "react-dom": "^17.0.1",
    "react-draft-wysiwyg": "^1.14.6",
    "react-dropzone": "^11.5.1",
    "react-fontawesome": "^1.7.1",
    "react-helmet": "^6.1.0",
    "react-hook-form": "^6.15.0",
    "react-idle-timer": "^4.4.2",
    "react-input-autosize": "^3.0.0",
    "react-plotly.js": "^2.5.1",
    "react-responsive": "^8.1.1",
    "react-router": "^5.2.0",
    "react-router-dom": "^5.2.0",
    "react-router-hash-link": "^2.3.1",
    "react-router-prop-types": "^1.0.5",
    "react-select": "^5.7.4",
    "react-stickynode": "^4.0.0",
    "react-with-direction": "^1.3.1",
    "sass": "^1.94.0",
    "url-join": "^4.0.1",
    "use-deep-compare-effect": "^1.6.1",
    "uuid": "^8.3.2"
  },
  "engines": {
    "node": "22.22.0"
  },
  "scripts": {
    "start": "vite",
    "build:local": "cross-env VITE_LOCAL_BUILD=true vite build",
    "build": "vite build",
    "test": "cross-env TZ=America/New_York jest --watch",
    "test:ci": "cross-env TZ=America/New_York JEST_JUNIT_OUTPUT_DIR=reports JEST_JUNIT_OUTPUT_NAME=unit.xml CI=true node --expose-gc ./node_modules/jest/bin/jest.js --coverage --silent --reporters=default --detectOpenHandles --forceExit --reporters=jest-junit --logHeapUsage",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "lint:fix:single": "eslint --fix",
    "lint:ci": "eslint -f eslint-formatter-multiple src"
  },
  "resolutions": {
    "dompurify": "^3.3.2",
    "lodash": "^4.18.1",
    "react-error-overlay": "6.0.11",
    "tar": "^7.5.11"
  },
  "eslintConfig": {
    "root": true,
    "parserOptions": {
      "ecmaVersion": "latest"
    },
    "plugins": [
      "testing-library"
    ],
    "extends": [
      "airbnb",
      "plugin:jest/recommended",
      "plugin:testing-library/react",
      "plugin:react-hooks/recommended"
    ],
    "ignorePatterns": [
      "build/*",
      "node_modules/*",
      "public/*"
    ],
    "rules": {
      "react/jsx-filename-extension": [
        1,
        {
          "extensions": [
            ".js",
            ".jsx"
          ]
        }
      ],
      "linebreak-style": 0
    },
    "env": {
      "jest/globals": true,
      "browser": true
    }
  },
  "eslint-formatter-multiple": {
    "formatters": [
      {
        "name": "stylish",
        "output": "console"
      },
      {
        "name": "junit",
        "output": "file",
        "path": "reports/lint.xml"
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.28.4",
    "@sheerun/mutationobserver-shim": "^0.3.3",
    "@testing-library/dom": "^8.11.1",
    "@testing-library/jest-dom": "^5.11.9",
    "@testing-library/react": "^12.1.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^13.5.0",
    "@types/node": "^22.15.30",
    "@types/react": "^17.0.89",
    "@types/react-dom": "^17.0.26",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.2",
    "eslint": "^7.20.0",
    "eslint-config-airbnb": "^18.2.0",
    "eslint-formatter-multiple": "^1.0.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-jest": "^24.1.5",
    "eslint-plugin-jsx-a11y": "^6.3.1",
    "eslint-plugin-react": "^7.20.5",
    "eslint-plugin-react-hooks": "^4.0.8",
    "eslint-plugin-testing-library": "^3.10.1",
    "fetch-mock": "^9.11.0",
    "history": "4.10.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-junit": "^13.0.0",
    "mutationobserver-shim": "^0.3.7",
    "postcss": "^8.4.39",
    "react-select-event": "^5.1.0",
    "typescript": "^5.8.3",
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^7.1.12"
  },
  "jest": {
    "clearMocks": true,
    "coveragePathIgnorePatterns": [
      "<rootDir>/src/index.js",
      "<rootDir>/src/pages/NotFound/index.js",
      "<rootDir>/src/polyfills.js",
      "<rootDir>/src/pages/Widgets/index.js",
      "<rootDir>/src/widgets/Example.js",
      "<rootDir>/src/pages/RegionalDashboard/formatDateRange.js",
      "<rootDir>/src/pages/RegionalDashboard/constants.js",
      "<rootDir>/src/pages/makecolors.js",
      "<rootDir>/src/NetworkContext.js",
      "<rootDir>/src/hooks/helpers.js",
      "<rootDir>/src/testHelpers.js",
      "<rootDir>/src/pages/activityReports/testHelpers.js"
    ],
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/node_modules/uuid/dist/index.js",
      "\\.(css|less|sass|scss)$": "<rootDir>/scripts/jest/styleMock.cjs",
      "\\.(gif|ttf|eot|svg|png|jpg|jpeg|webp)$": "<rootDir>/scripts/jest/fileMock.cjs"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.js"
    ],
    "testEnvironment": "jsdom",
    "transformIgnorePatterns": [
      "/node_modules/(?!(?:@react-hook|@juggle)/)"
    ],
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "babelrc": false,
          "configFile": "./babel.jest.config.cjs"
        }
      ]
    },
    "coverageThreshold": {
      "global": {
        "statements": 90,
        "functions": 90,
        "branches": 90,
        "lines": 90
      }
    }
  }
}
