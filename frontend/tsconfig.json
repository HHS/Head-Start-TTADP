{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": false,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node", "jest"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "build", "coverage"]
}
