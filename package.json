{
  "name": "head-start-ttadp",
  "version": "1.0.0",
  "description": "Office of Head Start Training & Technical Assistance Data Platform",
  "main": "index.js",
  "private": true,
  "engines": {
    "node": "22.22.0"
  },
  "scripts": {
    "build": "tsc -p src",
    "server": "tsx watch src/index.ts",
    "start:be": "node ./build/server/src/index.js",
    "start:debug": "nodemon --inspect=0.0.0.0:9229 src/index.js --exec babel-node",
    "start:fe": "yarn --cwd frontend start",
    "start:worker": "node ./build/server/src/worker.js",
    "start:worker:watch": "tsx watch src/worker.ts",
    "start:stack:local": "concurrently \"yarn server\" \"yarn start:fe\" \"yarn start:worker:watch\"",
    "start:stack:ci": "cross-env BYPASS_SOCKETS=true POSTGRES_USERNAME=postgres POSTGRES_DB=ttasmarthub TTA_SMART_HUB_URI=http://localhost:3000 concurrently \"yarn start:be\" \"yarn start:fe\" \"yarn start:testingonly\"",
    "start:testingonly": "node ./build/server/src/testingOnly.js",
    "deps": "yarn deps:frozen",
    "deps:install": "yarn install && yarn --cwd frontend install",
    "deps:frozen": "yarn install --frozen-lockfile && yarn --cwd frontend install --frozen-lockfile",
    "deps:audit": "./tools/run-yarn-audit.js && cd frontend && ../tools/run-yarn-audit.js",
    "db:migrate": "sequelize db:migrate && yarn db:ldm",
    "db:migrate:ci": "bin/ci-env sequelize db:migrate && yarn db:ldm:ci",
    "db:migrate:prod": "sequelize db:migrate --options-path .production.sequelizerc",
    "db:migrate:create": "npx sequelize-cli migration:generate --name",
    "db:migrate:undo": "sequelize db:migrate:undo && yarn db:ldm",
    "db:migrate:undo:prod:last": "sequelize db:migrate:undo --options-path .production.sequelizerc",
    "db:migrate:undo:prod:all": "sequelize db:migrate:undo:all --options-path .production.sequelizerc",
    "db:seed": "sequelize db:seed:all",
    "db:seed:local": "yarn db:seed",
    "db:seed:ci": "bin/ci-env sequelize db:seed:all",
    "db:seed:prod": "sequelize db:seed:all --options-path .production.sequelizerc",
    "db:seed:undo": "sequelize db:seed:undo:all",
    "db:seed:undo:prod": "sequelize db:seed:undo:all --options-path .production.sequelizerc",
    "db:ldm": "tsx ./src/tools/logicalDataModelCLI.ts",
    "db:ldm:ci": "bin/ci-env tsx ./src/tools/logicalDataModelCLI.ts",
    "db:validate:filenames": "node ./src/tools/validateDbFilenames.js",
    "db:validation": "node ./build/server/src/tools/dataValidationCLI.js",
    "cli:change-report-status": "bin/run-tool src/tools/changeReportStatusCLI.js",
    "cli:create-goals": "bin/run-tool src/tools/goalPilotCLI.js",
    "cli:create-monitoring-goals": "bin/run-tool src/tools/createMonitoringGoalsCLI.js",
    "cli:db-bootstrap-admin": "bin/run-tool src/tools/bootstrapAdminCLI.js",
    "cli:db-maintenance": "bin/run-tool src/tools/dbMaintenanceCLI.ts",
    "cli:import-goals": "bin/run-tool src/tools/importTTAPlanGoals.js",
    "cli:import-hses": "bin/run-tool src/tools/importGrantRecipientsCLI.js",
    "cli:import-reports": "bin/run-tool src/tools/importSSActivityReports.js",
    "cli:import-system": "bin/run-tool src/tools/importSystemCLI.ts",
    "cli:maintain-monitoring-data": "bin/run-tool src/tools/maintainMonitoringDataCLI.js",
    "cli:populate-legacy-resource-titles": "bin/run-tool src/tools/populateLegacyResourceTitlesCli.js",
    "cli:process-data": "bin/run-tool src/tools/processDataCLI.js",
    "cli:query-monitoring-data": "bin/run-tool src/tools/queryMonitoringDataCLI.js",
    "cli:queue-exercise:live": "bin/run-tool src/tools/queueExerciseLiveCLI.ts",
    "cli:reconcile-legacy": "bin/run-tool src/tools/reconcileLegacyReports.js",
    "cli:restore-topics": "bin/run-tool src/tools/restoreTopicsCLI.js",
    "cli:update-completed-event-report-pilots": "bin/run-tool src/tools/updateCompletedEventReportPilotsCLI.js",
    "cli:updateMonitoringFactTables": "bin/run-tool src/tools/updateMonitoringFactTablesCLI.ts",
    "lint": "biome lint src --reporter=default --diagnostic-level=error",
    "lint:all": "yarn lint && yarn --cwd frontend lint",
    "lint:ci": "mkdir -p lint-reports && biome lint --diagnostic-level=error --reporter junit src --reporter-file=lint-reports/lint-backend.xml",
    "lint:ci:all": "yarn lint:ci && yarn --cwd frontend lint:ci",
    "lint:fix": "biome check --write src",
    "lint:fix:all": "yarn lint:fix && yarn --cwd frontend lint:fix",
    "lint:fix:single": "biome check --write --no-errors-on-unmatched",
    "test": "yarn build && jest build/server/src --runInBand",
    "test:ci": "./bin/test-backend-ci",
    "test:all": "yarn test:ci && yarn --cwd frontend test:ci",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.js",
    "test:e2e:api": "playwright test --config=tests/api/playwright.config.js",
    "test:e2e:utils": "playwright test --config=tests/utilsTests/playwright.config.js",
    "test:e2e:ci": "TTA_SMART_HUB_URI=http://localhost:3000 yarn test:e2e",
    "test:e2e:ui": "npx playwright test --ui tests/e2e",
    "test:bdd": "cucumber-js --publish ./cucumber/features/*.feature -f json:./reports/cucumber_report.json && node ./cucumber/index.js",
    "test:bdd:ci": "TTA_SMART_HUB_URI=http://localhost:3000 yarn test:bdd",
    "docker:start": "task stack-up",
    "docker:start:full": "task stack-up-full",
    "docker:stop": "task stack-down",
    "docker:logs": "task stack-logs",
    "docker:refresh": "task refresh",
    "docker:reset": "task reset",
    "docker:shell": "task stack-shell",
    "docker:shell:backend": "task stack-shell TARGET=backend",
    "docker:shell:frontend": "task stack-shell TARGET=frontend",
    "docker:dss": "./bin/prod-style-server",
    "docker:db:migrate": "task stack-run TARGET=backend -- yarn db:migrate",
    "docker:db:migrate:undo": "task stack-run TARGET=backend -- yarn db:migrate:undo",
    "docker:db:seed": "task stack-run TARGET=backend -- yarn db:seed",
    "docker:db:seed:undo": "task stack-run TARGET=backend -- yarn db:seed:undo",
    "docker:ldm": "task stack-run TARGET=backend -- yarn db:ldm",
    "docker:lint": "task stack-run TARGET=backend -- yarn lint:ci && task stack-run TARGET=frontend -- yarn lint:ci",
    "docker:lint:fix": "task stack-run TARGET=backend -- yarn lint:fix && task stack-run TARGET=frontend -- yarn lint:fix",
    "docker:import:system": "task stack-run TARGET=backend -- yarn cli:import-system",
    "docker:makecolors": "task stack-run TARGET=frontend -- yarn util:makecolors",
    "coverage:backend": "./bin/build-coverage-report",
    "coverage:clean": "rm -rf coverage reports frontend/coverage frontend/reports frontend/build",
    "coverage:merge": "node ./tools/merge-coverage.js",
    "check-coverage": "node ./tools/check-coverage.js --fail-on-uncovered=true",
    "docs:serve": "npx @redocly/cli preview-docs -p 5003 docs/openapi/index.yaml",
    "util:makecolors": "node ./src/makecolors.js",
    "publish:common": "yarn --cwd ./packages/common publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adhocteam/Head-Start-TTADP.git"
  },
  "resolutions": {
    "@tootallnate/once": "^3.0.1",
    "fast-xml-parser": "^5.5.7",
    "flatted": "^3.4.2",
    "lodash": "^4.18.1",
    "nodemailer": "^8.0.4",
    "sqlite3": "^5.1.7",
    "tar": "^7.5.11"
  },
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/build/"
    ],
    "moduleNameMapper": {
      "^file-type$": "<rootDir>/src/__mocks__/file-type.js"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/frontend/",
      "<rootDir>/node_modules/",
      "<rootDir>/build/",
      "<rootDir>/src/makecolors.js",
      "<rootDir>/src/newrelic.js",
      "<rootDir>/src/testUtils.js",
      "<rootDir>/src/logger.js",
      "<rootDir>/src/*/coverage/",
      "<rootDir>/packages/",
      "<rootDir>/src/coverage/",
      "<rootDir>/src/index.js",
      "<rootDir>/src/worker.ts",
      "<rootDir>/src/app.js",
      "<rootDir>/src/tools/*CLI.js",
      "<rootDir>/src/tools/*Cli.js",
      "<rootDir>/src/tools/populateLegacyResourceTitlesCLI.js",
      "<rootDir>/src/tools/importTTAPlanGoals.js"
    ],
    "testTimeout": 30000,
    "coveragePathIgnorePatterns": [
      "<rootDir>/src/middleware/newRelicMiddleware.js",
      "<rootDir>/frontend/",
      "<rootDir>/node_modules",
      "<rootDir>/build/",
      "<rootDir>/packages/",
      "<rootDir>/src/makecolors.js",
      "<rootDir>/src/newrelic.js",
      "<rootDir>/src/testUtils.js",
      "<rootDir>/src/logger.js",
      "<rootDir>/src/*/coverage/",
      "<rootDir>/src/coverage/",
      "<rootDir>/src/index.ts",
      "<rootDir>/src/worker.ts",
      "<rootDir>/src/app.js",
      "<rootDir>/src/tools/*CLI.js",
      "<rootDir>/src/tools/*Cli.js",
      "<rootDir>/src/tools/populateLegacyResourceTitlesCli.js",
      "<rootDir>/src/tools/importTTAPlanGoals.js"
    ],
    "coverageReporters": [
      "json",
      "lcov",
      "text",
      "clover"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 90,
        "functions": 88,
        "branches": 80,
        "lines": 90
      }
    },
    "setupFiles": [
      "./src/setupTest.js",
      "./src/envParser.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/adhocteam/Head-Start-TTADP/issues"
  },
  "homepage": "https://github.com/adhocteam/Head-Start-TTADP#readme",
  "nodemonConfig": {
    "ignore": [
      "./reports/",
      "./cucumber/",
      "./frontend/",
      "./tests/",
      "./playwright/",
      "./playwright-report/",
      "./test-results/",
      "./playwright.config.js"
    ]
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.0",
    "@babel/cli": "^7.11.6",
    "@babel/core": "^7.11.6",
    "@babel/node": "^7.10.5",
    "@babel/plugin-transform-runtime": "^7.11.0",
    "@babel/preset-env": "^7.11.5",
    "@babel/preset-typescript": "^7.18.6",
    "@biomejs/biome": "^2.3.14",
    "@cucumber/cucumber": "^12.2.0",
    "@playwright/test": "^1.56.1",
    "@redocly/cli": "^2.7.0",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.9.1",
    "babel-jest": "29.7.0",
    "concurrently": "^7.0.0",
    "cross-env": "^7.0.2",
    "depcheck": "^1.2.0",
    "esm": "^3.2.25",
    "ioredis-mock": "^8.13.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "jest": "29.7.0",
    "jest-junit": "^12.0.0",
    "markdown-table": "^3.0.4",
    "mock-fs": "^5.4.1",
    "nodemon": "^2.0.4",
    "nyc": "^17.1.0",
    "puppeteer": "^13.1.1",
    "puppeteer-select": "^1.0.3",
    "selenium-webdriver": "4.3.0",
    "sinon": "^15.0.0",
    "supertest": "^6.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0",
    "umzug": "^3.2.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/lib-storage": "^3.1012.0",
    "@aws-sdk/s3-request-presigner": "^3.1012.0",
    "@axe-core/playwright": "^4.11.0",
    "@babel/runtime": "^7.26.10",
    "@braintree/sanitize-url": "^7.1.1",
    "@faker-js/faker": "^6.3.1",
    "@mesh-kit/core": "^1.0.0",
    "@opensearch-project/opensearch": "^1.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/otlp-exporter-base": "^0.207.0",
    "@ttahub/common": "2.2.21",
    "@types/ioredis-mock": "^8.2.6",
    "adm-zip": "^0.5.1",
    "ajv": "^8.18.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws4": "^1.11.0",
    "axios": "^1.13.5",
    "bull": "^4.16.5",
    "chardet": "^2.0.0",
    "cheerio": "^1.1.2",
    "client-oauth2": "^4.3.3",
    "cls-hooked": "^4.2.2",
    "connect-redis": "6",
    "cookie-session": "^2.0.0",
    "core-js": "^3.46.0",
    "cron": "1.8.3",
    "csv-parse": "^4.14.1",
    "csv-stringify": "^5.6.2",
    "cucumber-html-reporter": "^5.2.0",
    "deepmerge": "^4.3.1",
    "dompurify": "^3.3.2",
    "dot-wild": "^3.0.1",
    "dotenv": "^16.4.1",
    "email-templates": "^13.0.1",
    "express": "^4.22.0",
    "express-http-context": "^1.2.4",
    "express-session": "^1.18.2",
