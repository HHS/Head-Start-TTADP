#!/bin/bash
# This script sets up the system as run-owasp-scan expects it
set -euxo pipefail

mkdir -p reports/server
rm -f reports/server/*

docker compose -f docker/compose/dss.yml down --remove-orphans
docker compose -f docker/compose/dss.yml run server yarn install 
docker compose -f docker/compose/dss.yml run server yarn --cwd frontend install
docker compose -f docker/compose/dss.yml run server yarn build
docker compose -f docker/compose/dss.yml run server yarn --cwd frontend run build
docker compose -f docker/compose/dss.yml run server yarn db:migrate:ci
docker compose -f docker/compose/dss.yml up
