#!/bin/bash

echo 'Setting site to be indexable in robots.txt'

write_robots() {
  local target="$1"
  cat >"${target}" <<EOL
# Welcome Robots
User-agent: *
Disallow:
EOL
}

write_robots frontend/public/robots.txt

if [[ -d build/server/client ]]; then
  write_robots build/server/client/robots.txt
elif [[ -d frontend/build ]]; then
  write_robots frontend/build/robots.txt
fi
