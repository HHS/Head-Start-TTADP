#!/usr/bin/env bash

# Disable audit logging on the SequelizeData table, which is used by Sequelize to track which seeders have been run. 
# By default, audit triggers are attached to all tables including SequelizeData, which has no id column. 
# This causes inserting seed metadata to fail.
set -euo pipefail

export PGPASSWORD="${POSTGRES_PASSWORD:-}"

psql \
  -U ${POSTGRES_USERNAME} \
  -h ${POSTGRES_HOST}\
  -d ${POSTGRES_DB} \
  -p 5432\
  -v ON_ERROR_STOP=1 <<'SQL'
-- Create the table to store historial seeding data
CREATE TABLE IF NOT EXISTS "SequelizeData" (
    name VARCHAR(255) NOT NULL,
    PRIMARY KEY (name)
);

-- Remove auditing triggers
DO $$
BEGIN
    IF to_regprocedure('"ZAFRemoveAuditingOnTable"(varchar)') IS NOT NULL THEN
        PERFORM "ZAFRemoveAuditingOnTable"('SequelizeData');
    END IF;
END $$;

-- Drop the audit table if it exists
DROP TABLE IF EXISTS "ZALSequelizeData";
SQL

echo "Pre-seed setup complete."