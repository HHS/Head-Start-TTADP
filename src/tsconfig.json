{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "../build/server",
    "esModuleInterop": true,
    "declaration": false,
    "allowJs": true,
    "removeComments": true,
    "types": ["jest"]
  },
  "include": [
    "./**/*.js",
    "./**/*.ts",
    "../tests/**/*.js",
    "../tools/**/*.js"
  ]
}
