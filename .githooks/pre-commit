#!/usr/bin/env bash
set -euo pipefail

collect_staged_files() {
  local -n files_ref=$1

  while IFS= read -r -d '' file; do
    files_ref+=("$file")
  done < <(git diff --cached --name-only --diff-filter=ACMR -z)
}

run_biome_fix() {
  local dir=$1
  shift
  local files=("$@")

  if [ ${#files[@]} -eq 0 ]; then
    return 0
  fi

  if [ "$dir" = "." ]; then
    yarn lint:fix:single "${files[@]}"
    return
  fi

  (
    cd "$dir"
    yarn lint:fix:single "${files[@]}"
  )
}

validate_circleci_config() {
  if [[ -x "$(command -v circleci)" ]]; then
    circleci config validate > /dev/null
  fi
}

format_terraform_file() {
  local file=$1
  
  if [[ -x "$(command -v terraform)" ]]; then
    printf "Running: 'terraform fmt' on %s\n\n" "$file"
    terraform fmt "$file"
  fi
}

validate_common_versioning() {
  local common_changed=$1
  local common_package_json_changed=$2
  local frontend_yarn_lock_changed=$3
  local backend_yarn_lock_changed=$4

  if [ "$common_changed" != true ]; then
    return 0
  fi

  if [ "$common_package_json_changed" != true ]; then
    echo "ERROR: common/src/index.js was changed, but common/package.json was not updated. Please make sure to publish a new version."
    exit 1
  fi

  if [ "$frontend_yarn_lock_changed" != true ] || [ "$backend_yarn_lock_changed" != true ]; then
    echo "ERROR: common/src/index.js was changed, but a yarn.lock file was not updated. Please make sure you've updated both yarn.lock files if you've updated the common/index.js file."
    exit 1
  fi
}

main() {
  staged_files=()
  collect_staged_files staged_files

  if [ ${#staged_files[@]} -eq 0 ]; then
    exit 0
  fi

  validate_circleci_config

  common_changed=false
  common_package_json_changed=false
  frontend_yarn_lock_changed=false
  backend_yarn_lock_changed=false
  root_biome_files=()
  frontend_biome_files=()

  for file in "${staged_files[@]}"; do

    if [ ! -e "$file" ]; then
      continue
    fi

    case "$file" in
      packages/common/src/index.js)
        common_changed=true
        ;;
      packages/common/package.json)
        common_package_json_changed=true
        ;;
      frontend/yarn.lock)
        frontend_yarn_lock_changed=true
        ;;
      yarn.lock)
        backend_yarn_lock_changed=true
        ;;
    esac

    case "$file" in
      *.tf)
        format_terraform_file "$file"
        ;;
      frontend/*)
        frontend_biome_files+=("${file#frontend/}")
        ;;
      *)
        root_biome_files+=("$file")
        ;;
    esac
  done

  run_biome_fix "." "${root_biome_files[@]}"
  run_biome_fix "frontend" "${frontend_biome_files[@]}"

  git add -- "${staged_files[@]}"

  validate_common_versioning \
    "$common_changed" \
    "$common_package_json_changed" \
    "$frontend_yarn_lock_changed" \
    "$backend_yarn_lock_changed"
}

main